generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OPERATOR
  MANAGER
}

enum Stage {
  CUTTING
  STITCHING
  FINISHING
  PACKING
  COMPLETED
}

enum Location {
  FACTORY_STORE
  DISPATCH
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime          @default(now())
  transitions  StageTransition[]
}

model Style {
  id        String         @id @default(cuid())
  sku       String         @unique
  name      String
  createdAt DateTime       @default(now())
  bundles   Bundle[]
  stock     StockBalance[]
}

model Bundle {
  id           String            @id
  styleId      String
  quantity     Int
  currentStage Stage             @default(CUTTING)
  createdAt    DateTime          @default(now())
  style        Style             @relation(fields: [styleId], references: [id])
  transitions  StageTransition[]

  @@index([currentStage])
  @@index([styleId])
}

model StockBalance {
  id        String   @id @default(cuid())
  styleId   String
  location  Location
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt
  style     Style    @relation(fields: [styleId], references: [id])

  @@unique([styleId, location])
}

model StageTransition {
  id        String   @id @default(cuid())
  bundleId  String
  fromStage Stage
  toStage   Stage
  userId    String
  createdAt DateTime @default(now())
  bundle    Bundle   @relation(fields: [bundleId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([bundleId])
  @@index([createdAt])
}

model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  response  Json
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}
