{
  "name": "@connoisseur/mobile",
  "version": "1.0.0",
  "main": "index.tsx",
  "private": true,
  "scripts": {
    "prestart": "lsof -ti:8081 | xargs kill -9 2>/dev/null || true",
    "start": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo start --go --clear --port 8081 --lan",
    "start:tunnel": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo start --go --clear --tunnel --port 8081",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "^6.1.2",
    "babel-preset-expo": "~54.0.11",
    "expo": "~54.0.35",
    "expo-camera": "~17.0.10",
    "expo-haptics": "~15.0.8",
    "expo-modules-core": "~3.0.30",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "metro": "^0.83.3",
    "metro-runtime": "^0.83.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.17",
    "typescript": "~5.9.3"
  }
}
